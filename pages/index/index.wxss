/* pages/index/index.wxss */
.container {
  padding: 30rpx;
  background-color: #f8fafc;
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
}

.header-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.lang-toggle {
  background: #fff;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid #eee;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
  transition: background-color 0.15s ease, transform 0.15s ease;
}

.lang-toggle-hover {
  background: #eef8f1;
  transform: scale(0.94);
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #db2777;
  background: linear-gradient(to right, #db2777, #0284c7);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

.event-section {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding-left: 20rpx;
  position: relative;
  flex: 1;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 4rpx;
  bottom: 4rpx;
  width: 8rpx;
  background: linear-gradient(to bottom, #db2777, #0284c7);
  border-radius: 4rpx;
}

.today-btn {
  padding: 8rpx 22rpx;
  border: 1rpx solid #bbf7d0;
  border-radius: 999rpx;
  background: #fff;
  color: #047857;
  font-size: 24rpx;
  line-height: 1.4;
  flex-shrink: 0;
  transition: background-color 0.15s ease, transform 0.15s ease;
}

.today-btn-hover {
  background: #eef8f1;
  transform: scale(0.94);
}

.event-list {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx 0;
  margin: 0;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03);
}

.event-row {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 16rpx 18rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  overflow: hidden;
  position: relative;
  transition: background-color 0.15s ease;
}

.event-row::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18rpx;
  bottom: 18rpx;
  width: 6rpx;
  border-radius: 0 4rpx 4rpx 0;
  background: #cbd5e1;
  transition: background-color 0.2s ease;
}

.event-row-atp::before {
  background: #0284c7;
}

.event-row-wta::before {
  background: #db2777;
}

.event-row:last-child {
  border-bottom: none;
}

.event-row-hover {
  background: #eef8f1;
}

.row-number {
  width: 34rpx;
  margin-right: 8rpx;
  color: #999;
  text-align: right;
  flex-shrink: 0;
  white-space: nowrap;
}

.row-flag {
  margin-right: 10rpx;
  font-size: 32rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.row-main {
  flex: 1;
  min-width: 0;
}

.row-title-line {
  display: flex;
  min-width: 0;
}

.row-name {
  flex: 1;
  min-width: 0;
  overflow: visible;
  white-space: normal;
  word-break: break-word;
}

.row-name-primary {
  display: block;
  color: #333;
  font-weight: 600;
  line-height: 1.4;
  word-break: break-word;
}

.row-name-secondary {
  display: block;
  margin-top: 4rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 400;
  word-break: break-word;
}

.row-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.meta-icons {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meta-icon {
  width: 72rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.row-badge {
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #334155;
  font-size: 22rpx;
  line-height: 1.3;
  white-space: nowrap;
}

.tour-badge {
  background: #e0f2fe;
  color: #0369a1;
  font-weight: 600;
}

.tour-level-badge {
  font-weight: 600;
}

.tour-level-badge-atp {
  background: #e0f2fe;
  color: #0284c7;
}

.tour-level-badge-wta {
  background: #fce7f3;
  color: #db2777;
}

.surface-badge {
  background: #ecfdf5;
  color: #047857;
}

.row-location {
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.4;
  word-break: break-word;
}

.no-events {
  padding: 60rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.prompt-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.28);
}

.prompt-panel {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  overflow: hidden;
  background: #fff;
  border-radius: 20rpx;
  padding: 34rpx 30rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.16);
}

.prompt-accent {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  height: 8rpx;
  background: linear-gradient(to right, #db2777, #0284c7);
}

.prompt-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #333;
  word-break: break-word;
}

.prompt-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #666;
  word-break: break-word;
}

.prompt-divider {
  margin-top: 20rpx;
  border-top: 1rpx dashed #86efac;
}

.prompt-event {
  margin-top: 20rpx;
  padding-left: 18rpx;
  position: relative;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #333;
  word-break: break-word;
}

.prompt-event-flag {
  margin-right: 10rpx;
}

.prompt-event::before {
  content: "";
  position: absolute;
  left: 0;
  top: 4rpx;
  bottom: 4rpx;
  width: 6rpx;
  background: linear-gradient(to bottom, #db2777, #0284c7);
  border-radius: 4rpx;
}

.prompt-event-primary {
  display: block;
  word-break: break-word;
}

.prompt-event-secondary {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 400;
  word-break: break-word;
}

.prompt-detail-list {
  margin-top: 20rpx;
}

.prompt-detail-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  line-height: 1.55;
}

.prompt-detail-row:last-child {
  border-bottom: none;
}

.prompt-detail-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 400;
  flex-shrink: 0;
}

.prompt-detail-label::after {
  content: ": ";
}

.lang-zh .prompt-detail-label::after {
  content: "：";
}

.prompt-detail-value {
  color: #333;
  flex: 1;
  min-width: 0;
  word-break: break-word;
}

.prompt-message {
  display: block;
  margin-top: 24rpx;
  color: #666;
  font-size: 26rpx;
  line-height: 1.55;
  word-break: break-word;
}

.prompt-actions {
  display: flex;
  justify-content: flex-end;
  gap: 18rpx;
  margin-top: 32rpx;
}

.prompt-btn {
  min-width: 156rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 64rpx;
  font-weight: 500;
  box-sizing: border-box;
  transition: background-color 0.15s ease, transform 0.15s ease;
}

.prompt-btn::after {
  border: none;
}

.prompt-btn-secondary {
  border: 1rpx solid #86efac;
  background: #fff;
  color: #047857;
}

.prompt-btn-primary {
  background: linear-gradient(to right, #dcfce7, #fef3c7, #dbeafe);
  color: #047857;
}

.prompt-btn-hover {
  background: #eef8f1;
  transform: scale(0.95);
}

.prompt-btn-primary-hover {
  filter: brightness(0.94);
  transform: scale(0.95);
}
