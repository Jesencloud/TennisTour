<!-- components/calendar/calendar.wxml -->
<view class="calendar-container">
  <view class="calendar-header">
    <view class="nav-btn" hover-class="nav-btn-hover" hover-stay-time="100" bindtap="prevMonth">❮</view>
    <picker
      mode="date"
      fields="month"
      value="{{currentYear}}-{{currentMonth + 1 < 10 ? '0' + (currentMonth + 1) : (currentMonth + 1)}}"
      start="{{baseYear}}-01"
      end="{{baseYear + 1}}-12"
      bindchange="onMonthPickerChange"
    >
      <view class="current-month" hover-class="current-month-hover">
        {{monthNames[currentMonth]}} {{currentYear}}
      </view>
    </picker>
    <view class="nav-btn" hover-class="nav-btn-hover" hover-stay-time="100" bindtap="nextMonth">❯</view>
  </view>

  <view class="weekday-header">
    <block wx:for="{{weekdays}}" wx:key="*this">
      <view class="weekday-item">{{item}}</view>
    </block>
  </view>

  <view class="calendar-days-viewport">
    <swiper
      class="calendar-swiper"
      current="{{swiperCurrent}}"
      duration="{{swiperDuration}}"
      easing-function="easeOutCubic"
      bindanimationfinish="onCalendarSwiperFinish"
      bindtouchstart="onTouchStart"
    >
      <block wx:for="{{monthPanels}}" wx:key="key" wx:for-item="panel">
        <swiper-item class="month-panel">
          <view class="days-grid">
            <block wx:for="{{panel.days}}" wx:key="dateKey" wx:for-item="day">
              <view
                class="day-item {{day.fullDate === selectedDate ? 'selected' : ''}} {{day.isPast ? 'past' : ''}} {{!day.day ? 'empty' : ''}}"
                hover-class="{{!day.day ? 'none' : 'day-item-hover'}}"
                hover-stay-time="100"
                bindtap="selectDay"
                data-date="{{day.fullDate}}"
              >
                <view class="day-num">{{day.day}}</view>
                <view
                  wx:if="{{day.day}}"
                  class="event-badge {{day.hasEvent ? '' : 'event-badge-empty'}}"
                >
                  <text wx:for="{{day.eventBadges}}" wx:key="label" class="event-badge-line event-badge-{{item.tone}}">{{item.label}}</text>
                </view>
              </view>
            </block>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

</view>
