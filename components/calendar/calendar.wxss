/* components/calendar/calendar.wxss */
.calendar-container {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.nav-btn {
  padding: 20rpx;
  color: #666;
  font-size: 32rpx;
}

.current-month {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
}

.current-month-hover {
  background: #eef8f1;
}

.calendar-days-viewport {
  width: 100%;
  overflow: hidden;
}

.calendar-days-track {
  display: flex;
  width: 300%;
  margin-left: -100%;
}

.weekday-header {
  display: flex;
  margin-bottom: 20rpx;
}

.weekday-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.month-panel {
  width: 33.3333%;
  flex: 0 0 33.3333%;
}

.day-item {
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  transition: transform 0.12s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.day-item-hover {
  transform: scale(0.85);
}

.day-item.empty {
  visibility: hidden;
}

.day-num {
  font-size: 30rpx;
  color: #333;
  z-index: 1;
}

.day-item.selected {
  background: #dcfce7;
  border-radius: 50%;
}

.day-item.selected .day-num {
  font-weight: bold;
  color: #047857;
}

.day-item.past .day-num {
  color: #b8b8b8;
}

.day-item.past .event-dot {
  background: #d1d5db;
}

.day-item.past .event-icon {
  opacity: 0.42;
}

.event-dot {
  width: 40rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(to right, #047857, #16a34a, #ca8a04, #2563eb);
  margin-top: 8rpx;
}

.event-icon {
  width: 62rpx;
  height: 24rpx;
  margin-top: 4rpx;
  display: block;
}

.month-picker-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.28);
}

.month-picker-panel {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.16);
}

.month-picker-header {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.year-option {
  min-width: 132rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 34rpx;
  color: #333;
}

.year-option.active {
  color: #047857;
  font-weight: bold;
  background: #eef8f1;
}

.month-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.month-option {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #333;
  font-size: 28rpx;
}

.month-option.active {
  color: #047857;
  font-weight: bold;
  background: #eef8f1;
  border-radius: 16rpx;
}
