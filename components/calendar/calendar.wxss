/* components/calendar/calendar.wxss */
.calendar-container {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f8fafc;
  color: #475569;
  font-size: 26rpx;
  transition: all 0.2s ease;
}

.nav-btn-hover {
  background: #fce7f3;
  color: #db2777;
  transform: scale(0.9);
}

.current-month {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  transition: background-color 0.2s ease;
}

.current-month-hover {
  background: #fce7f3;
  color: #db2777;
}

.calendar-days-viewport {
  width: 100%;
  height: 600rpx;
  overflow: hidden;
}

.calendar-swiper {
  width: 100%;
  height: 600rpx;
}

.weekday-header {
  display: flex;
  margin-bottom: 20rpx;
}

.weekday-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
}

.days-grid {
  height: 600rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  grid-auto-rows: 100rpx;
  align-content: space-between;
}

.month-panel {
  width: 100%;
  height: 600rpx;
}

.day-item {
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  transition: transform 0.12s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.day-item-hover {
  transform: scale(0.85);
}

.day-item.empty {
  visibility: hidden;
}

.day-num {
  font-size: 30rpx;
  color: #333;
  z-index: 1;
}

.day-item.selected {
  background: #dcfce7;
  border-radius: 50%;
}

.day-item.selected .day-num {
  font-weight: bold;
  color: #047857;
}

.day-item.past .day-num {
  color: #b8b8b8;
}

.event-badge {
  display: flex;
  width: 100%;
  min-height: 18rpx;
  margin-top: 2rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 15rpx;
  line-height: 17rpx;
  font-weight: 600;
  color: #047857;
  text-align: center;
  overflow: hidden;
}

.event-badge-line {
  display: block;
  max-width: 96rpx;
  white-space: nowrap;
  overflow: hidden;
}

.event-badge-wta {
  color: #db2777;
}

.event-badge-atp {
  color: #0284c7;
}

.event-badge-crown {
  font-size: 22rpx;
  line-height: 24rpx;
}

.event-badge-empty {
  visibility: hidden;
}

.day-item.past .event-badge {
  opacity: 0.42;
}

.month-picker-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.28);
}

.month-picker-panel {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.16);
}

.month-picker-header {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.year-option {
  min-width: 132rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 34rpx;
  color: #333;
}

.year-option.active {
  color: #047857;
  font-weight: bold;
  background: #eef8f1;
}

.month-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.month-option {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #333;
  font-size: 28rpx;
}

.month-option.active {
  color: #047857;
  font-weight: bold;
  background: #eef8f1;
  border-radius: 16rpx;
}
